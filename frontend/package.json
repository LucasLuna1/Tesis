    "xlsx": "^0.18.5"
  },
  "overrides": {
    "date-fns": "^2.30.0"
  },
  "scripts": {
    "start": "cross-env GENERATE_SOURCEMAP=false craco start",
    "build": "cross-env GENERATE_SOURCEMAP=false ESLINT_NO_DEV_ERRORS=true CI=false craco build",
    "build:prod": "cross-env NODE_ENV=production GENERATE_SOURCEMAP=false ESLINT_NO_DEV_ERRORS=true CI=false craco build",
    "test": "craco test",
    "eject": "react-scripts eject",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "analyze": "npm run build && npx bundle-analyzer build/static/js/*.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "cross-env": "^10.1.0",
    "typescript": "^4.9.5"
  },
  "proxy": "http://localhost:5000"
}
